/**
 * 游导旅游 - 首页样式
 */

/* ===== 页面基础 ===== */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 32rpx;
}

/* ===== 搜索栏 ===== */
.search-bar {
  padding: 24rpx 32rpx;
  background: #4F86F7;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #999;
}

/* ===== Banner轮播 ===== */
.banner-section {
  margin-top: -48rpx;
  padding: 0 32rpx;
}

.banner-swiper {
  height: 280rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.banner-1 {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.banner-2 {
  background: linear-gradient(135deg, #4F86F7 0%, #3B82F6 100%);
}

.banner-3 {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.banner-content {
  color: #fff;
  text-align: center;
  padding: 40rpx;
}

.banner-tag {
  display: inline-block;
  font-size: 22rpx;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.banner-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

/* ===== 快捷入口 ===== */
.quick-entry {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
  background: #fff;
  margin: 24rpx 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.quick-entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-entry-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.quick-entry-text {
  font-size: 24rpx;
  color: #666;
}

/* ===== 区块通用 ===== */
.section {
  margin: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.section-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.section-more {
  font-size: 26rpx;
  color: #4F86F7;
}

/* ===== 导游卡片 ===== */
.guide-scroll {
  white-space: nowrap;
}

.guide-cards {
  display: inline-flex;
  gap: 24rpx;
}

.guide-card {
  width: 280rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  position: relative;
}

.guide-avatar {
  width: 80rpx;
  height: 80rpx;
  background: #E8F2FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.guide-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.guide-info {
  display: flex;
  flex-direction: column;
}

.guide-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.guide-langs {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.guide-rating {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  font-size: 22rpx;
}

.guide-rating .star {
  font-size: 22rpx;
}

.guide-rating .score {
  color: #FFB800;
  margin-left: 4rpx;
}

.guide-rating .count {
  color: #999;
  margin-left: 4rpx;
}

.guide-specialty {
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 目的地网格 ===== */
.destination-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.destination-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.destination-bg {
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
}

.destination-info {
  padding: 16rpx;
  text-align: center;
}

.destination-name {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.destination-count {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* ===== 工具卡片 ===== */
.tools-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.tool-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.tool-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin: 0 auto 12rpx;
}

.tool-name {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.tool-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* ===== 平台数据 ===== */
.stats-section {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: linear-gradient(135deg, #4F86F7 0%, #3B82F6 100%);
  margin: 32rpx;
  border-radius: 16rpx;
  padding: 40rpx 24rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-number {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.stats-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.3);
}

/* ===== 徽章 ===== */
.badge-hot {
  background: #FFF2F0;
  color: #FF4D4F;
}

/* ===== 按钮 ===== */
.btn-primary {
  background: linear-gradient(135deg, #4F86F7 0%, #3B82F6 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
}
