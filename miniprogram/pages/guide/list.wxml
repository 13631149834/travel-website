<!--
  游导旅游 - 导游列表页
-->
<view class="page">
  <!-- 顶部筛选栏 -->
  <view class="filter-bar">
    <view class="filter-tabs">
      <view class="filter-tab {{currentFilter === 'all' ? 'active' : ''}}" bindtap="onFilterTap" data-filter="all">全部</view>
      <view class="filter-tab {{currentFilter === 'hot' ? 'active' : ''}}" bindtap="onFilterTap" data-filter="hot">热门</view>
      <view class="filter-tab {{currentFilter === 'recommended' ? 'active' : ''}}" bindtap="onFilterTap" data-filter="recommended">优选</view>
    </view>
    <view class="filter-sort" bindtap="onSortTap">
      <text>{{sortText}}</text>
      <text class="sort-arrow">▼</text>
    </view>
  </view>

  <!-- 导游列表 -->
  <view class="guide-list">
    <view class="guide-item" wx:for="{{guides}}" wx:key="id" bindtap="onGuideTap" data-id="{{item.id}}">
      <view class="guide-avatar">{{item.avatar}}</view>
      <view class="guide-content">
        <view class="guide-header">
          <text class="guide-name">{{item.name}}</text>
          <view class="guide-badges">
            <text class="badge badge-hot" wx:if="{{item.isHot}}">热门</text>
            <text class="badge badge-primary" wx:if="{{item.isRecommended}}">优选</text>
          </view>
        </view>
        <text class="guide-langs">{{item.languages}}</text>
        <view class="guide-rating">
          <text class="stars">⭐⭐⭐⭐⭐</text>
          <text class="score">{{item.rating}}</text>
          <text class="count">({{item.reviewCount}}条评价)</text>
        </view>
        <text class="guide-specialty">{{item.specialty}}</text>
        <view class="guide-footer">
          <text class="guide-price">¥{{item.price}}/天</text>
          <view class="guide-btn">立即预约</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    <text bindtap="loadMore">加载更多</text>
  </view>
  
  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!guides.length}}">
    <text class="empty-icon">🎤</text>
    <text class="empty-text">暂无导游</text>
  </view>
</view>
