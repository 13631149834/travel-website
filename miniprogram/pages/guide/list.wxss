/**
 * 游导旅游 - 导游列表页样式
 */

/* ===== 页面基础 ===== */
.page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* ===== 筛选栏 ===== */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-tabs {
  display: flex;
  gap: 32rpx;
}

.filter-tab {
  font-size: 28rpx;
  color: #666;
  padding: 8rpx 0;
  border-bottom: 4rpx solid transparent;
}

.filter-tab.active {
  color: #4F86F7;
  border-bottom-color: #4F86F7;
  font-weight: 500;
}

.filter-sort {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.sort-arrow {
  font-size: 20rpx;
}

/* ===== 导游列表 ===== */
.guide-list {
  padding: 24rpx 32rpx;
}

.guide-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.guide-avatar {
  width: 120rpx;
  height: 120rpx;
  background: #E8F2FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  flex-shrink: 0;
}

.guide-content {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.guide-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.guide-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.guide-badges {
  display: flex;
  gap: 8rpx;
}

.guide-langs {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.guide-rating {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.guide-rating .stars {
  font-size: 20rpx;
  letter-spacing: -2rpx;
}

.guide-rating .score {
  font-size: 26rpx;
  color: #FFB800;
  font-weight: 500;
  margin-left: 8rpx;
}

.guide-rating .count {
  font-size: 22rpx;
  color: #999;
  margin-left: 8rpx;
}

.guide-specialty {
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.guide-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.guide-price {
  font-size: 32rpx;
  color: #FF4D4F;
  font-weight: 600;
}

.guide-btn {
  background: linear-gradient(135deg, #4F86F7 0%, #3B82F6 100%);
  color: #fff;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

/* ===== 徽章 ===== */
.badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.badge-hot {
  background: #FFF2F0;
  color: #FF4D4F;
}

.badge-primary {
  background: #E8F2FF;
  color: #4F86F7;
}

/* ===== 加载更多 ===== */
.load-more {
  text-align: center;
  padding: 32rpx;
  color: #4F86F7;
  font-size: 28rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 24rpx;
}
