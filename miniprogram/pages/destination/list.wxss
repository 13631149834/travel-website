/**
 * 游导旅游 - 目的地页样式
 */

/* ===== 页面基础 ===== */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 32rpx;
}

/* ===== 轮播推荐 ===== */
.featured-section {
  padding: 24rpx 32rpx;
}

.featured-swiper {
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.featured-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 40rpx;
}

.featured-emoji {
  font-size: 120rpx;
  margin-right: 32rpx;
}

.featured-info {
  color: #fff;
  flex: 1;
}

.featured-name {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.featured-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
}

.featured-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  opacity: 0.8;
}

.dot {
  margin: 0 12rpx;
}

/* ===== 分类标签 ===== */
.category-section {
  padding: 0 32rpx 24rpx;
  background: #fff;
}

.category-tabs {
  display: flex;
  gap: 24rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding: 8rpx 0;
}

.category-tab {
  padding: 12rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 30rpx;
  flex-shrink: 0;
}

.category-tab.active {
  background: #4F86F7;
  color: #fff;
}

/* ===== 目的地网格 ===== */
.destination-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 24rpx 32rpx;
}

.destination-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.destination-cover {
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.destination-emoji {
  font-size: 80rpx;
}

.destination-info {
  padding: 20rpx;
}

.destination-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.destination-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.destination-tag {
  font-size: 20rpx;
  color: #FF4D4F;
}

.destination-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.destination-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.destination-guides {
  font-size: 22rpx;
  color: #666;
}

.destination-price {
  font-size: 26rpx;
  color: #FF4D4F;
  font-weight: 600;
}
