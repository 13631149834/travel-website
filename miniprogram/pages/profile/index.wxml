<!--
  游导旅游 - 个人中心页
-->
<view class="page">
  <!-- 用户信息区域 -->
  <view class="profile-header">
    <view class="profile-bg"></view>
    <view class="profile-content">
      <view class="profile-avatar" bindtap="onAvatarTap">
        {{isLoggedIn ? userInfo.avatar : '👤'}}
      </view>
      <view class="profile-info" wx:if="{{isLoggedIn}}">
        <text class="profile-name">{{userInfo.nickname}}</text>
        <text class="profile-id">ID: {{userInfo.id}}</text>
      </view>
      <view class="profile-info" wx:else>
        <text class="profile-name">点击登录</text>
        <text class="profile-desc">登录后享受更多服务</text>
      </view>
    </view>
  </view>

  <!-- 会员卡 -->
  <view class="member-card">
    <view class="member-left">
      <text class="member-title">{{isLoggedIn ? '尊享会员' : '成为会员'}}</text>
      <text class="member-desc">{{isLoggedIn ? '畅享更多特权' : '解锁专属优惠'}}</text>
    </view>
    <view class="member-btn">{{isLoggedIn ? '查看权益' : '立即加入'}}</view>
  </view>

  <!-- 订单入口 -->
  <view class="order-section">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <view class="section-more" bindtap="onOrdersTap">
        <text>全部订单</text>
        <text>></text>
      </view>
    </view>
    <view class="order-items">
      <view class="order-item" bindtap="onOrderTap" data-type="pending">
        <text class="order-icon">⏰</text>
        <text class="order-text">待支付</text>
      </view>
      <view class="order-item" bindtap="onOrderTap" data-type="confirmed">
        <text class="order-icon">✅</text>
        <text class="order-text">待确认</text>
      </view>
      <view class="order-item" bindtap="onOrderTap" data-type="ongoing">
        <text class="order-icon">🎯</text>
        <text class="order-text">进行中</text>
      </view>
      <view class="order-item" bindtap="onOrderTap" data-type="completed">
        <text class="order-icon">📝</text>
        <text class="order-text">待评价</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onMenuTap" data-type="favorites">
      <text class="menu-icon">❤️</text>
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-type="reviews">
      <text class="menu-icon">⭐</text>
      <text class="menu-text">我的评价</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-type="coupons">
      <text class="menu-icon">🎫</text>
      <text class="menu-text">优惠券</text>
      <text class="menu-badge">3</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-type="guide-apply">
      <text class="menu-icon">🎤</text>
      <text class="menu-text">申请成为导游</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="onMenuTap" data-type="help">
      <text class="menu-icon">❓</text>
      <text class="menu-text">帮助与反馈</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-type="settings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-type="about">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" bindtap="onLogoutTap" wx:if="{{isLoggedIn}}">
    退出登录
  </view>
</view>
