/**
 * 游导旅游 - 个人中心页样式
 */

/* ===== 页面基础 ===== */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 48rpx;
}

/* ===== 用户信息区域 ===== */
.profile-header {
  position: relative;
  padding: 48rpx 32rpx 80rpx;
}

.profile-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 240rpx;
  background: linear-gradient(135deg, #4F86F7 0%, #3B82F6 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.profile-content {
  position: relative;
  display: flex;
  align-items: center;
  z-index: 1;
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  border: 6rpx solid #fff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.profile-info {
  margin-left: 28rpx;
  color: #fff;
}

.profile-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
}

.profile-id {
  display: block;
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 6rpx;
}

.profile-desc {
  display: block;
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 6rpx;
}

/* ===== 会员卡 ===== */
.member-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  margin: -40rpx 32rpx 24rpx;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(255,165,0,0.3);
}

.member-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.member-desc {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 4rpx;
}

.member-btn {
  background: #fff;
  color: #FFA500;
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* ===== 订单区域 ===== */
.order-section {
  background: #fff;
  margin: 0 32rpx 24rpx;
  border-radius: 16rpx;
  padding: 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #999;
}

.order-items {
  display: flex;
  justify-content: space-around;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.order-text {
  font-size: 24rpx;
  color: #666;
}

/* ===== 功能菜单 ===== */
.menu-section {
  background: #fff;
  margin: 0 32rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-badge {
  background: #FF4D4F;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* ===== 退出登录 ===== */
.logout-btn {
  background: #fff;
  margin: 48rpx 32rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #FF4D4F;
}
