<button class="timer-btn submit" onclick="submitExam()">交卷</button>
</div>
</div>

<div class="exam-progress">
<span id="answeredCount">0</span>/<span id="totalQuestions">0</span> 已答
<div class="progress-bar"><div class="fill" id="progressFill"></div></div>
</div>

<div id="examQuestionsArea">
  <!-- 题目卡片 -->
  <div id="singleQuestionWrap"></div>
  
  <!-- 题目导航 -->
  <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;margin-top:8px;">
    <button id="prevBtn" onclick="prevQuestion()" style="padding:10px 20px;background:#F8F9FA;border:1px solid #F0F0F0;border-radius:10px;color:#666;font-size:0.9rem;cursor:pointer;touch-action:manipulation;">← 上一题</button>
    <span id="qProgress" style="font-size:0.85rem;color:#666;">1 / 20</span>
    <button id="nextBtn" onclick="nextQuestion()" style="padding:10px 20px;background:#4C8BF5;border:none;border-radius:10px;color:#fff;font-size:0.9rem;font-weight:600;cursor:pointer;touch-action:manipulation;">下一题 →</button>
  </div>
  
  <!-- 答题卡 -->
  <div style="margin-top:16px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
      <span style="font-size:0.85rem;color:#666;">答题卡</span>
      <button onclick="toggleAnswerCard()" style="background:none;border:none;color:#4C8BF5;font-size:0.8rem;cursor:pointer;">收起/展开</button>
    </div>
    <div id="answerCard" style="display:flex;flex-wrap:wrap;gap:6px;padding:12px;background:#F8F9FA;border-radius:12px;"></div>
  </div>
</div>
</div>

<!-- 考试结果区域 -->
<div id="examResult" class="hidden">
<div class="exam-result" id="resultCard">
<div class="score-big" id="resultScore">0</div>
<div class="score-label">最终得分</div>
<div class="score-detail">
<div class="score-item"><div class="num" id="resultCorrect">0</div><div class="label">答对</div></div>
<div class="score-item"><div class="num" id="resultWrong">0</div><div class="label">答错</div></div>
<div class="score-item"><div class="num" id="resultTotal">0</div><div class="label">总题数</div></div>
</div>
<div class="result-msg" id="resultMsg"></div>
</div>

<div id="wrongAnalysis"></div>

<button class="reveal-btn" onclick="retakeExam()" style="width:100%;margin-top:16px;">重新考试</button>
</div>

<!-- 错题本区域 -->
<div id="wrongBookSection" class="hidden">
<div class="wrong-book-view">
<div id="wrong-book-content">
