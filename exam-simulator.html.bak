<!-- AI练习 -->
<div class="section-block">
<h2><span class="icon">🤖</span>AI智能练习</h2>
<p class="section-desc">告别题海战术，让AI根据你的薄弱环节生成个性化练习题</p>
<div class="tip-box">
<strong>🤖 AI备考助手</strong>
<p style="margin-top:8px;">输入薄弱知识点，AI自动生成针对性练习题<br>支持历年真题讲解、知识点问答、模拟试卷生成</p>
<a href="chat.html" style="display:inline-block;margin-top:12px;padding:10px 20px;background:#FFFFFF;color:#666666;border-radius:20px;font-size:0.9rem;font-weight:600;">立即开始AI练习 →</a>
</div>
<div class="item-grid" style="margin-top:16px;">
<div class="item-card">
<h4>薄弱点突破</h4>
<p>告诉AI你不理解的知识点，AI用案例讲解直到你懂</p>
</div>
<div class="item-card">
<h4>真题答疑</h4>
<p>拍照上传错题，AI分析错误原因并举一反三</p>
</div>
</div>
</div>

</div>

<button class="back-to-top" id="backToTop" onclick="scrollToTop()">↑</button>

<!-- 底部Tab栏 -->
';
  
  <script>
  // Initialize exam state
  userAnswers = {};
  answeredQuestions = {};
  currentQIndex = 0;
  
  // Start with first question
  renderSingleQuestion(0);
  renderAnswerCard();
  
  // Start timer
  startTimer();

var currentQIndex = 0;

// ========== 正式考试题库 ==========
var examQuestions = [
  // 政策法规
  {type:'policy',question:'根据《旅游法》，旅行社应当向导游支付不低于当地最低工资标准的报酬，这一规定体现了什么原则？',options:['A. 公平原则','B. 保障原则','C. 平等原则','D. 诚信原则'],answer:1,analysis:'《旅游法》第38条规定，旅行社应当与其聘用的导游依法订立劳动合同，支付劳动报酬，不得要求导游垫付费用，体现了保障原则。'},
  {type:'policy',question:'导游在进行导游活动时，其行为规范由哪部法律来规范？',options:['A. 合同法','B. 旅游法','C. 消费者权益保护法','D. 民法通则'],answer:1,analysis:'导游行为主要由《旅游法》规范，同时受《导游管理办法》等行政法规约束。'},
  {type:'policy',question:'旅行社组织团队旅游，应当与旅游者订立什么？',options:['A. 口头协议','B. 旅游合同','C. 谅解备忘录','D. 行程确认单'],answer:1,analysis:'《旅游法》第57条规定，旅行社组织和安排旅游活动，应当与旅游者订立书面旅游合同。'},
  {type:'policy',question:'导游证的有效期为几年？',options:['A. 1年','B. 2年','C. 3年','D. 5年'],answer:2,analysis:'《导游管理办法》规定，导游证的有效期为3年。'},
  {type:'policy',question:'以下哪项不属于导游的权利？',options:['A. 获取劳动报酬','B. 人身权','C. 自由变更行程','D. 参加培训'],answer:2,analysis:'导游无权自由变更行程，行程变更需经旅行社同意并告知旅游者。'},
  // 导游业务
  {type:'service',question:'导游服务的核心是？',options:['A. 购物安排','B. 讲解服务','C. 食宿安排','D. 交通安排'],answer:1,analysis:'导游服务的核心是讲解服务，通过讲解使旅游者获得知识和审美享受。'},
  {type:'service',question:'地陪导游的服务对象是？',options:['A. 出境旅游者','B. 入境旅游者','C. 本地旅游者','D. 所有旅游者'],answer:1,analysis:'地陪导游主要服务入境旅游者，负责在当地进行导游讲解和安排相关服务。'},
  {type:'service',question:'导游在团队出发前的准备工作不包括？',options:['A. 熟悉接待计划','B. 准备导游词','C. 与旅游者签订合同','D. 检查所需物品'],answer:2,analysis:'签订合同是旅行社的工作，不是导游出发前的准备内容。'},
  {type:'service',question:'以下哪项是导游在旅游途中应做的？',options:['A. 随意更改行程','B. 关注旅游者安全','C. 强制购物','D. 索要小费'],answer:1,analysis:'导游在旅游途中应关注旅游者安全，不得随意更改行程、强制购物或索要小费。'},
  {type:'service',question:'全陪导游的职责是？',options:['A. 负责景点讲解','B. 负责全程陪同','C. 负责餐饮安排','D. 负责购物安排'],answer:1,analysis:'全陪导游负责全程陪同旅游团，协调联络，处理突发事件，保障旅游者权益。'},
  // 全国导基
  {type:'guidebook',question:'中国最长的河流是？',options:['A. 黄河','B. 珠江','C. 长江','D. 淮河'],answer:2,analysis:'长江全长6300公里，是中国最长的河流，也是世界第三大河流。'},
  {type:'guidebook',question:'北京的故宫旧称是？',options:['A. 颐和园','B. 紫禁城','C. 圆明园','D. 天坛'],answer:1,analysis:'北京故宫旧称紫禁城，是中国明清两代的皇家宫殿，世界最大古建筑群。'},
  {type:'guidebook',question:'以下哪个不属于中国五岳？',options:['A. 泰山','B. 华山','C. 黄山','D. 嵩山'],answer:2,analysis:'中国五岳为东岳泰山、西岳华山、南岳衡山、北岳恒山、中岳嵩山，黄山不属于五岳。'},
  {type:'guidebook',question:'中国四大佛教名山中，属于安徽的是？',options:['A. 五台山','B. 峨眉山','C. 九华山','D. 普陀山'],answer:2,analysis:'九华山位于安徽省池州市，是中国佛教四大名山之一，地藏菩萨道场。'},
  // 地方导基
  {type:'local',question:'「桂林山水甲天下」形容的是哪个景区？',options:['A. 漓江','B. 西湖','C. 太湖','D. 滇池'],answer:0,analysis:'「桂林山水甲天下」形容的是广西桂林漓江风景区，以喀斯特地貌闻名。'},
  {type:'local',question:'以下哪个省份有「彩云之南」的美称？',options:['A. 贵州','B. 四川','C. 云南','D. 广西'],answer:2,analysis:'云南省因位于云岭以南，素有「彩云之南」的美称。'},
  {type:'local',question:'以下哪个城市有「天府之国」的美称？',options:['A. 重庆','B. 成都','C. 昆明','D. 西安'],answer:1,analysis:'成都位于四川盆地西部，因物产丰富被称为「天府之国」。'},
  {type:'local',question:'以下哪个是云南著名的旅游景点？',options:['A. 故宫','B. 丽江古城','C. 西湖','D. 泰山'],answer:1,analysis:'丽江古城位于云南省丽江市，是世界文化遗产，以独特的纳西族文化闻名。'},
  {type:'local',question:'以下哪个是四川著名的旅游景点？',options:['A. 故宫','B. 九寨沟','C. 西湖','D. 黄山'],answer:1,analysis:'九寨沟位于四川省阿坝藏族羌族自治州，以翠海、叠瀑、彩林、雪峰、藏情、蓝冰「六绝」著称。'},

  // === 扩充题目 - 政策法规 ===
  {type:'policy',question:'旅行社应当投保什么保险？',options:['A. 车辆保险','B. 旅行社责任保险','C. 游客意外险','D. 财产保险'],answer:1,analysis:'《旅游法》规定旅行社必须投保旅行社责任保险，保障游客权益。'},
  {type:'policy',question:'旅游者有权要求旅行社提供什么？',options:['A. 免费升级','B. 真实可靠的旅游服务信息','C. 购物优惠券','D. 额外景点'],answer:1,analysis:'旅游者有权获得真实可靠的旅游服务信息，旅行社不得作虚假宣传。'},
  {type:'policy',question:'旅行社不得安排旅游者参加什么活动？',options:['A. 参观博物馆','B. 违反社会公德的活动','C. 体验民俗文化','D. 品尝当地美食'],answer:1,analysis:'旅行社不得安排违反社会公德或危害旅游者人身安全的活动。'},
  {type:'policy',question:'导游证持有人每年应完成多少学时继续教育？',options:['A. 12学时','B. 24学时','C. 36学时','D. 48学时'],answer:1,analysis:'根据规定，导游证持有人每年应完成不少于24学时的继续教育。'},
  {type:'policy',question:'旅游纠纷投诉电话是？',options:['A. 12315','B. 12301','C. 12345','D. 110'],answer:1,analysis:'全国旅游服务投诉热线是12301，旅游者可通过此号码投诉旅游纠纷。'},
  {type:'policy',question:'旅行社组织出境旅游，应当具备什么资质？',options:['A. 国内社资质','B. 出境社资质','C. 入境社资质','D. 边境社资质'],answer:1,analysis:'组织出境旅游需取得出境社资质，且需缴纳更高额的质量保证金。'},
  {type:'policy',question:'《旅游法》于哪年施行？',options:['A. 2011年','B. 2012年','C. 2013年','D. 2014年'],answer:2,analysis:'《中华人民共和国旅游法》于2013年10月1日起施行。'},
  {type:'policy',question:'导游在执业过程中应当佩戴什么？',options:['A. 工作证','B. 导游证','C. 身份证','D. 胸牌'],answer:1,analysis:'导游在执业过程中应当按规定佩戴导游证，接受旅游主管部门和旅游者监督。'},
  {type:'policy',question:'旅游者因个人原因解除合同的，旅行社应如何处理？',options:['A. 全额退款','B. 扣除必要费用后退还余额','C. 不予退款','D. 双倍赔偿'],answer:1,analysis:'旅游者因个人原因解除合同，旅行社在扣除必要费用后应将余额退还旅游者。'},
  {type:'policy',question:'国内旅行社质量保证金最低限额为多少？',options:['A. 10万元','B. 20万元','C. 30万元','D. 50万元'],answer:1,analysis:'国内旅行社质量保证金最低限额为20万元。'},
  {type:'policy',question:'旅行社不得以什么方式招徕旅游者？',options:['A. 网络宣传','B. 传单广告','C. 不正当竞争','D. 电视广告'],answer:2,analysis:'旅行社不得以不正当竞争方式招徕旅游者，包括零团费、虚假宣传等。'},
  {type:'policy',question:'旅行社未与旅游者签订合同将面临什么处罚？',options:['A. 警告','B. 罚款2万-10万','C. 吊销执照','D. 停业整顿'],answer:1,analysis:'旅行社未与旅游者签订书面合同，可处以2万元以上10万元以下罚款。'},
  {type:'policy',question:'导游可以向旅游者索要小费吗？',options:['A. 可以','B. 不可以','C. 看情况','D. 服务好就可以'],answer:1,analysis:'《旅游法》明确禁止导游向旅游者索取小费。'},
  {type:'policy',question:'旅游团队在行程中遇到不可抗力，旅行社应如何处理？',options:['A. 继续行程','B. 取消行程','C. 经协商后调整行程','D. 由导游决定'],answer:2,analysis:'因不可抗力影响行程的，旅行社应与旅游者协商后调整行程，由此增加的费用由旅游者承担，减少的费用退还旅游者。'},
  {type:'policy',question:'旅行社安排购物次数一般不超过几次？',options:['A. 1次','B. 2次','C. 3次','D. 不限'],answer:0,analysis:'根据规定，旅行社安排购物次数一般不超过1次，且需征得旅游者同意。'},
  // === 扩充题目 - 导游业务 ===
  {type:'service',question:'导游接团后应首先做什么？',options:['A. 清点人数并致欢迎词','B. 安排住宿','C. 介绍景点','D. 发放资料'],answer:0,analysis:'导游接团后应首先清点人数并致欢迎词，确认旅游者到齐。'},
  {type:'service',question:'导游在车上讲解时应站在哪里？',options:['A. 车厢中部','B. 司机旁','C. 车尾','D. 车门口'],answer:1,analysis:'导游在车上讲解时应站在司机旁，便于使用话筒并关注前方路况。'},
  {type:'service',question:'旅游者走失后，导游应首先做什么？',options:['A. 报警','B. 全团寻找','C. 争取配合分头找','D. 联系旅行社'],answer:2,analysis:'旅游者走失后，导游应争取其他旅游者配合分头寻找，同时报告旅行社。'},
  {type:'service',question:'导游处理投诉的首要原则是？',options:['A. 耐心倾听','B. 直接拒绝','C. 推给旅行社','D. 与游客争辩'],answer:0,analysis:'导游处理投诉应耐心倾听，了解问题，积极寻求解决方案。'},
  {type:'service',question:'游客突发疾病，导游应首先？',options:['A. 自行施救','B. 拨打120','C. 联系旅行社','D. 通知家属'],answer:1,analysis:'游客突发疾病，导游应首先拨打120急救电话，同时报告旅行社。'},
  {type:'service',question:'导游接待原则中，最核心的是？',options:['A. 游客至上','B. 安全第一','C. 热情周到','D. 合理而可能'],answer:0,analysis:'游客至上是导游服务的核心原则，一切服务以游客利益为出发点。'},
  {type:'service',question:'"合理而可能"原则适用于？',options:['A. 购物安排','B. 游客个别要求','C. 行程变更','D. 讲解内容'],answer:1,analysis:'"合理而可能"原则主要适用于处理游客的个别要求，满足合理且可能实现的需求。'},
  {type:'service',question:'导游应提前多久到达集合地点？',options:['A. 5分钟','B. 10分钟','C. 15分钟','D. 30分钟'],answer:1,analysis:'导游应提前至少10分钟到达集合地点，做好出发前的准备工作。'},
  {type:'service',question:'交通事故发生后，导游应？',options:['A. 继续行程','B. 报警并组织救援','C. 等待指示','D. 让游客自理'],answer:1,analysis:'交通事故后，导游应立即报警并组织救援，同时报告旅行社。'},
  {type:'service',question:'食物中毒后，导游应？',options:['A. 给药','B. 送医并保留食物样本','C. 让休息','D. 联系餐厅'],answer:1,analysis:'食物中毒后，导游应送医并保留食物样本，配合调查。'},
  {type:'service',question:'导游欢迎词应包含什么内容？',options:['A. 自我介绍和行程概要','B. 酒店房型','C. 购物安排','D. 门票价格'],answer:0,analysis:'导游欢迎词应包含自我介绍、行程概要、注意事项等基本信息。'},
  {type:'service',question:'游客要求离团，导游应？',options:['A. 同意','B. 劝阻并告知风险','C. 强制跟随','D. 收额外费'],answer:1,analysis:'游客要求离团，导游应劝阻并告知风险，如游客坚持则让其在书面确认后离团。'},
  {type:'service',question:'导游讲解应避免？',options:['A. 互动提问','B. 照本宣科','C. 穿插故事','D. 适当幽默'],answer:1,analysis:'导游讲解应避免照本宣科，应生动有趣、因人而异。'},
  {type:'service',question:'导游在讲解时间上应？',options:['A. 全程讲','B. 景点前讲、路上适当休息','C. 不讲','D. 游客问才讲'],answer:1,analysis:'导游应合理安排讲解时间，景点前详细讲，路上适当休息，避免游客疲劳。'},
  {type:'service',question:'游客受伤后，导游应？',options:['A. 继续带团','B. 协助就医并报告','C. 让自理','D. 等行程结束'],answer:1,analysis:'游客受伤后，导游应协助就医并报告旅行社，不得置之不理。'},
  // === 扩充题目 - 全国导基 ===
  {type:'guidebook',question:'中国面积最大的省级行政区是？',options:['A. 西藏','B. 内蒙古','C. 新疆','D. 青海'],answer:2,analysis:'新疆维吾尔自治区面积约166万平方公里，是中国面积最大的省级行政区。'},
  {type:'guidebook',question:'五岳中的东岳是？',options:['A. 华山','B. 泰山','C. 衡山','D. 嵩山'],answer:1,analysis:'东岳泰山位于山东省泰安市，被尊为五岳之首。'},
  {type:'guidebook',question:'中国四大佛教名山中，五台山供奉哪位菩萨？',options:['A. 观音','B. 文殊','C. 普贤','D. 地藏'],answer:1,analysis:'五台山是文殊菩萨道场，位于山西省忻州市。'},
  {type:'guidebook',question:'长江三峡位于哪些省市？',options:['A. 川渝鄂','B. 川渝湘','C. 渝鄂赣','D. 川黔渝'],answer:0,analysis:'长江三峡位于四川、重庆、湖北三省市的交界处。'},
  {type:'guidebook',question:'秦始皇兵马俑在哪个省？',options:['A. 河南','B. 陕西','C. 山西','D. 甘肃'],answer:1,analysis:'秦始皇兵马俑位于陕西省西安市临潼区，是世界第八大奇迹。'},
  {type:'guidebook',question:'中国人口最多的省是？',options:['A. 山东','B. 河南','C. 广东','D. 四川'],answer:2,analysis:'广东省是中国人口最多的省份，常住人口超过1.2亿。'},
  {type:'guidebook',question:'中国最南端的省级行政区是？',options:['A. 广东','B. 海南','C. 台湾','D. 南海诸岛属海南'],answer:3,analysis:'中国最南端的省级行政区是海南省（含南海诸岛），曾母暗沙为最南端。'},
  {type:'guidebook',question:'黄山四绝是指？',options:['A. 奇松怪石云海温泉','B. 奇松怪石云海冬雪','C. 奇松怪石日出温泉','D. 奇松云海日出温泉'],answer:0,analysis:'黄山四绝为奇松、怪石、云海、温泉。'},
  {type:'guidebook',question:'以下哪个不属于中国四大名园？',options:['A. 颐和园','B. 避暑山庄','C. 拙政园','D. 华清池'],answer:3,analysis:'中国四大名园为颐和园、避暑山庄、拙政园、留园，华清池不属于。'},
  {type:'guidebook',question:'西湖十景中"断桥残雪"在哪个城市？',options:['A. 苏州','B. 杭州','C. 扬州','D. 南京'],answer:1,analysis:'断桥残雪是杭州西湖十景之一，位于白堤东端。'},
  {type:'guidebook',question:'中国四大发明不包括？',options:['A. 造纸术','B. 印刷术','C. 火药','D. 丝绸'],answer:3,analysis:'中国四大发明为造纸术、印刷术、火药、指南针，丝绸不属于四大发明。'},
  {type:'guidebook',question:'以下哪个不是世界文化遗产？',options:['A. 长城','B. 故宫','C. 泰山','D. 丽江古城'],answer:2,analysis:'泰山是世界文化与自然双重遗产，不仅是文化遗产。此题考的是"仅"文化遗产。'},
  {type:'guidebook',question:'中国最大的淡水湖是？',options:['A. 太湖','B. 洞庭湖','C. 鄱阳湖','D. 巢湖'],answer:2,analysis:'鄱阳湖是中国最大的淡水湖，位于江西省。'},
  {type:'guidebook',question:'以下哪个是道教名山？',options:['A. 五台山','B. 武当山','C. 普陀山','D. 九华山'],answer:1,analysis:'武当山是道教圣地，位于湖北省十堰市，是真武大帝的道场。'},
  {type:'guidebook',question:'中国"三大石窟"不包括？',options:['A. 莫高窟','B. 云冈石窟','C. 龙门石窟','D. 麦积山石窟'],answer:3,analysis:'中国三大石窟为莫高窟、云冈石窟、龙门石窟，麦积山石窟虽有名但不属三大。'},
  // === 扩充题目 - 地方导基 ===
  {type:'local',question:'北京的市花是？',options:['A. 月季和菊花','B. 牡丹','C. 玫瑰','D. 荷花'],answer:0,analysis:'北京市花是月季和菊花，月季为市花，菊花也是北京的象征之一。'},
  {type:'local',question:'上海的外滩在黄浦江的哪一侧？',options:['A. 东侧','B. 西侧','C. 北侧','D. 南侧'],answer:1,analysis:'外滩位于黄浦江西侧，是上海的标志性景观。'},
  {type:'local',question:'西安的古城墙是哪个朝代修建的？',options:['A. 唐朝','B. 宋朝','C. 明朝','D. 清朝'],answer:2,analysis:'西安古城墙始建于明朝洪武年间，是中国现存最完整的古城墙。'},
  {type:'local',question:'杭州的灵隐寺以什么闻名？',options:['A. 道教文化','B. 佛教禅宗','C. 儒家书院','D. 伊斯兰建筑'],answer:1,analysis:'灵隐寺是杭州著名的佛教禅宗寺院，始建于东晋。'},
  {type:'local',question:'成都被称为"天府之国"的原因是？',options:['A. 气候温和','B. 物产丰富','C. 人口众多','D. 历史悠久'],answer:1,analysis:'成都因四川盆地物产丰富、农业发达，被称为"天府之国"。'},
  {type:'local',question:'重庆的别称是？',options:['A. 江城','B. 山城','C. 蓉城','D. 锦城'],answer:1,analysis:'重庆因地形多山，被称为"山城"，也因多雾被称为"雾都"。'},
  {type:'local',question:'南京的夫子庙是什么性质的建筑？',options:['A. 佛教寺庙','B. 孔庙建筑群','C. 道教宫观','D. 皇家园林'],answer:1,analysis:'南京夫子庙是供奉祭祀孔子的孔庙建筑群，也是著名的文化旅游区。'},
  {type:'local',question:'昆明的别称是？',options:['A. 春城','B. 花城','C. 山城','D. 江城'],answer:0,analysis:'昆明因四季如春，被称为"春城"。'},
  {type:'local',question:'拉萨的布达拉宫最初是为何而建？',options:['A. 宗教寺庙','B. 王宫','C. 军事要塞','D. 学校'],answer:1,analysis:'布达拉宫最初是吐蕃赞普松赞干布为迎娶文成公主而建的宫殿。'},
  {type:'local',question:'广州的"羊城"别称来源于什么传说？',options:['A. 五羊献穗','B. 羊入城池','C. 牧羊少年','D. 羊角传说'],answer:0,analysis:'广州"羊城"别称来源于五位仙人骑五羊献稻穗的传说，象征丰收吉祥。'},
  {type:'local',question:'苏州园林中最著名的是？',options:['A. 留园','B. 拙政园','C. 狮子林','D. 网师园'],answer:1,analysis:'拙政园是苏州园林中面积最大、最著名的一座，被列为世界文化遗产。'},
  {type:'local',question:'天津的"狗不理"是什么？',options:['A. 烧饼','B. 包子','C. 饺子','D. 馄饨'],answer:1,analysis:'"狗不理"是天津著名的传统小吃，以包子闻名。'},
  {type:'local',question:'武汉的"黄鹤楼"在哪个区？',options:['A. 武昌区','B. 汉口区','C. 汉阳区','D. 洪山区'],answer:0,analysis:'黄鹤楼位于武汉市武昌区蛇山之巅，是中国四大名楼之一。'},
  {type:'local',question:'青岛的标志建筑是？',options:['A. 栈桥','B. 八大关','C. 崂山','D. 五四广场'],answer:0,analysis:'栈桥是青岛的标志性建筑，建于1892年，是青岛的象征。'},
  {type:'local',question:'厦门的鼓浪屿以什么特色著称？',options:['A. 美食','B. 钢琴之岛','C. 武术','D. 陶瓷'],answer:1,analysis:'鼓浪屿因钢琴密度全国第一，被称为"钢琴之岛"，2017年列入世界文化遗产。'},
  // === 扩充题目 - 面试 ===
  {type:'interview',question:'导游面试讲解时间一般多长？',options:['A. 3-5分钟','B. 5-8分钟','C. 8-15分钟','D. 15-30分钟'],answer:2,analysis:'导游面试讲解时间一般为8-15分钟，考官会根据实际情况控制。'},
  {type:'interview',question:'面试考官一般几位？',options:['A. 1位','B. 2-3位','C. 5位','D. 7位'],answer:1,analysis:'面试考官一般为2-3位，包括主考官和副考官。'},
  {type:'interview',question:'面试中"景区讲解"主要考查什么？',options:['A. 背诵能力','B. 讲解技能和语言表达','C. 体能','D. 歌唱能力'],answer:1,analysis:'景区讲解主要考查考生的讲解技能、语言表达能力和仪态仪表。'},
  {type:'interview',question:'导游面试着装应？',options:['A. 随意休闲','B. 正装或职业装','C. 运动装','D. 晚礼服'],answer:1,analysis:'导游面试应着正装或职业装，整洁大方，体现专业形象。'},
  {type:'interview',question:'面试中遇到不会的问题应？',options:['A. 沉默不语','B. 诚实回答并尝试分析','C. 胡编乱造','D. 反问考官'],answer:1,analysis:'面试中遇到不会的问题应诚实回答，展现分析问题的思路，不要编造。'},
  {type:'interview',question:'导游词讲解应注意什么？',options:['A. 快速讲完','B. 语速适中、情感丰富','C. 照稿念','D. 只讲数据'],answer:1,analysis:'导游词讲解应语速适中、情感丰富、富有感染力，避免照稿念。'},
  {type:'interview',question:'面试评分标准中占比最大的是？',options:['A. 仪态仪表','B. 语言表达','C. 景点讲解','D. 应变能力'],answer:2,analysis:'面试评分中景点讲解占比最大，通常占总分的40%-50%。'},
  {type:'interview',question:'导游面试中"规范服务"考查什么？',options:['A. 饮食习惯','B. 服务礼仪和规范操作','C. 睡眠安排','D. 娱乐活动'],answer:1,analysis:'规范服务考查考生的服务礼仪、接待规范和职业素养。'},
  {type:'interview',question:'面试中回答问题应？',options:['A. 越长越好','B. 简明扼要、条理清晰','C. 模糊应对','D. 反问考官'],answer:1,analysis:'面试回答应简明扼要、条理清晰，有理有据，避免啰嗦。'},
  {type:'interview',question:'导游面试的"应变能力"考什么？',options:['A. 体能','B. 处理突发事件的能力','C. 外语水平','D. 才艺表演'],answer:1,analysis:'应变能力考查考生处理突发事件、游客投诉等实际问题的能力。'},
  {type:'interview',question:'面试中可以用方言讲解吗？',options:['A. 可以全程用','B. 可以适当使用增添趣味','C. 绝对不行','D. 只能用方言'],answer:1,analysis:'面试以普通话为主，适当使用方言增添趣味是被允许的，但不能全程使用。'},

];

// ========== 正式考试启动函数 ==========
function startExam() {
  // Reset state
  userAnswers = {};
  answeredQuestions = {};
  currentQIndex = 0;
  
  // Random select questions from the pool for the exam
  var shuffled = examQuestions.slice().sort(function() { return Math.random() - 0.5; });
  examQuestions = shuffled.slice(0, Math.min(90, shuffled.length));
  
  // Update total count display
  var totalEl = document.getElementById('totalQuestions');
  if (totalEl) totalEl.textContent = examQuestions.length;
  
  // Reset timer
  remainingTime = 90 * 60; // 90 minutes
  updateTimerDisplay();
  
  // Start with first question
  renderSingleQuestion(0);
  renderAnswerCard();
  
  // Start timer
  startTimer();
}

var answeredQuestions = {};

function renderSingleQuestion(idx) {
  if(idx < 0 || idx >= examQuestions.length) return;
  currentQIndex = idx;
  var q = examQuestions[idx];
  
  // 防御性检查：如果题目数据有问题
  if(!q || typeof q.question === 'undefined') {
    document.getElementById('singleQuestionWrap').innerHTML = '<div style="text-align:center;padding:40px 20px;color:#666;"><p>题目数据加载中，请刷新重试...</p></div>';
    return;
  }
  var wrap = document.getElementById('singleQuestionWrap');
  var isAnswered = answeredQuestions[idx] !== undefined;
  var userAns = answeredQuestions[idx];
  
  var html = '<div class="question-card" style="animation:fadeIn 0.3s ease">';
  html += '<h4><span class="q-num">' + (idx+1) + '</span> ' + getTypeName(q.type) + '</h4>';
  html += '<p class="question-text" style="font-size:1rem;line-height:1.8;">' + q.question + '</p>';
  html += '<ul class="question-options">';
  
  q.options.forEach(function(opt, i) {
    var cls = '';
    if(isAnswered) {
      if(i === q.answer) cls = 'correct';
      else if(i === userAns && userAns !== q.answer) cls = 'wrong';
    } else if(userAnswers[idx] === i) {
      cls = 'selected';
    }
    var clickHandler = isAnswered ? '' : 'onclick="selectExamAnswer(' + idx + ',' + i + ')"';
    html += '<li class="' + cls + '" ' + clickHandler + '>' + opt + '</li>';
  });
  html += '</ul>';
  
  // 如果已回答，显示解析
  if(isAnswered) {
    html += '<div class="answer-box show" style="margin-top:12px;">';
    html += '<div class="correct-text">' + (userAns === q.answer ? '✅ 回答正确' : '❌ 回答错误，正确答案: ' + q.options[q.answer]) + '</div>';
    html += '<div class="analysis" style="margin-top:8px;">' + q.analysis + '</div>';
    html += '</div>';
  }

  
  html += '</div>';
  wrap.innerHTML = html;
  
  // 更新导航
  (document.getElementById('qProgress')||{}).textContent= (idx+1) + ' / ' + examQuestions.length;
  document.getElementById('prevBtn').style.opacity = idx === 0 ? '0.3' : '1';
  (document.getElementById('nextBtn')||{}).textContent= idx === examQuestions.length - 1 ? '交卷 📝' : '下一题 →';
  
  updateProgress();
}

window.selectExamAnswer = function(qIdx, optIdx) {if(typeof GameSystem!=='undefined')GameSystem.addQuestion();
  if(answeredQuestions[qIdx] !== undefined) return; // 已答过不再改
  userAnswers[qIdx] = optIdx;
  answeredQuestions[qIdx] = optIdx; // 直接确认，立刻出解析
  renderSingleQuestion(qIdx);
  updateAnswerCard(qIdx);
};

window.confirmAnswer = function(qIdx) {
  if(userAnswers[qIdx] === undefined) { alert('请先选择一个答案'); return; }
  answeredQuestions[qIdx] = userAnswers[qIdx];
  renderSingleQuestion(qIdx);
  updateAnswerCard(qIdx);
};

window.prevQuestion = function() {
  if(currentQIndex > 0) renderSingleQuestion(currentQIndex - 1);
};

window.nextQuestion = function() {
  if(currentQIndex < examQuestions.length - 1) {
    renderSingleQuestion(currentQIndex + 1);
  } else {
    submitExam();
  }
};

function renderAnswerCard() {
  var card = document.getElementById('answerCard');
  var html = '';
  examQuestions.forEach(function(q, i) {
    var bg = '#FFFFFF';
    var border = '#FFFFFF';
    var color = '#666666';
    if(answeredQuestions[i] !== undefined) {
      if(answeredQuestions[i] === q.answer) { bg = 'rgba(16,185,129,0.2)'; border = '#10b981'; color = '#10b981'; }
      else { bg = 'rgba(239,68,68,0.2)'; border = '#ef4444'; color = '#ef4444'; }
    } else if(userAnswers[i] !== undefined) { bg = 'rgba(76,139,245,0.2)'; border = '#4C8BF5'; color = '#4C8BF5'; }
    html += '<span onclick="renderSingleQuestion(' + i + ')" style="width:30px;height:30px;display:flex;align-items:center;justify-content:center;font-size:0.72rem;border-radius:6px;background:' + bg + ';border:1px solid ' + border + ';color:' + color + ';cursor:pointer;">' + (i+1) + '</span>';
  });
  card.innerHTML = html;
}

function updateAnswerCard(idx) {
  renderAnswerCard();
}

window.toggleAnswerCard = function() {
  var card = document.getElementById('answerCard');
  card.style.display = card.style.display === 'flex' ? 'none' : 'flex';
};

function getTypeName(type) {
  const names = {
    'policy': '📋 政策法规',
    'service': '🛎️ 导游业务',
    'guidebook': '📚 全国导基',
    'local': '🏙️ 地方导基'
  };
  return names[type] || '📝';
}




function updateProgress() {
  const answered = Object.keys(userAnswers).length;
  const total = examQuestions.length;
  (document.getElementById('answeredCount')||{}).textContent= answered;
  document.getElementById('progressFill').style.width = `${(answered / total) * 100}%`;
}

// ========== 计时器 ==========
function startTimer() {
  remainingTime = 90 * 60; // 正式考试90分钟
  updateTimerDisplay();
  
  if (timerInterval) clearInterval(timerInterval);
  timerInterval = setInterval(() => {
    remainingTime--;
    updateTimerDisplay();
    
    if (remainingTime <= 0) {
      clearInterval(timerInterval);
      submitExam();
    }
  }, 1000);
}

function updateTimerDisplay() {
  const mins = Math.floor(remainingTime / 60);
  const secs = remainingTime % 60;
  (document.getElementById('examTimer')||{}).textContent= 
    `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
}

function toggleTimer() {
  if (timerInterval) {
    clearInterval(timerInterval);
    timerInterval = null;
  } else {
    timerInterval = setInterval(() => {
      remainingTime--;
      updateTimerDisplay();
      if (remainingTime <= 0) {
        clearInterval(timerInterval);
        submitExam();
      }
    }, 1000);
  }
}

// ========== 交卷 ==========
function submitExam() {if(typeof GameSystem!=='undefined')GameSystem.addExam();
  if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
  
  // 自动确认所有未确认的答案
  examQuestions.forEach(function(q, i) {
    if(userAnswers[i] !== undefined && answeredQuestions[i] === undefined) {
      answeredQuestions[i] = userAnswers[i];
    }
  });
  
  let correct = 0;
  let wrong = 0;
  let unanswered = 0;
  const wrongList = [];
  
  examQuestions.forEach((q, index) => {
    const userAns = answeredQuestions[index];
    if (userAns === undefined) { unanswered++; wrong++; return; }
    if (userAns === q.answer) { correct++; }
    else {
      wrong++;
      wrongList.push({ index: index, question: q, userAnswer: userAns, correctAnswer: q.answer });
    }
  });
  
  const total = examQuestions.length;
  const score = Math.round((correct / total) * 100);
  const passScore = 60;
  const passed = score >= passScore;
  
  // 显示结果
  showExamResult(score, correct, wrong, total, passed, wrongList);
}

function showExamResult(score, correct, wrong, total, passed, wrongList) {
  document.getElementById('examSection').classList.add('hidden');
  document.getElementById('examResult').classList.remove('hidden');
  
  const resultCard = document.getElementById('resultCard');
  resultCard.classList.toggle('fail', !passed);
  
  (document.getElementById('resultScore')||{}).textContent= score + '分';
  (document.getElementById('resultCorrect')||{}).textContent= correct;
  (document.getElementById('resultWrong')||{}).textContent= wrong;
  (document.getElementById('resultTotal')||{}).textContent= total;
  (document.getElementById('resultMsg')||{}).textContent= passed ? '🎉 恭喜！预估通过考试！' : '💪 再接再厉，下次一定行！';
  if(typeof unanswered !== 'undefined' && unanswered > 0) (document.getElementById('resultMsg')||{}).textContent += '（' + unanswered + '题未作答）';
  
  // 显示错题解析
  const analysisHtml = wrongList.length > 0 ? `
    <div class="section-block" style="margin-top:16px;">
      <h3>📖 错题解析</h3>
      ${wrongList.map((item, i) => `
        <div class="question-card" style="background:rgba(239,68,68,0.08);border-color:#B91C1C;">
          <h4><span class="q-num">${item.index + 1}</span> ${getTypeName(item.question.type)}</h4>
          <p class="question-text">${item.question.question}</p>
          <div class="answer-box show">
            <div class="correct-text">你的答案: ${item.userAnswer !== undefined ? item.question.options[item.userAnswer] : '未作答'} | 正确答案: ${item.question.options[item.correctAnswer]}</div>
            <div class="analysis" style="margin-top:10px;">${item.question.analysis}</div>
          </div>
        </div>
      `).join('')}
    </div>
  ` : '';
  
  document.getElementById('wrongAnalysis').innerHTML = analysisHtml;
  

  document.getElementById('backToTop').scrollIntoView({ behavior: 'smooth' });
  
  // 更新学习进度到localStorage
  try {
    const PROGRESS_KEY = 'youdao_study_progress';
    let progress = JSON.parse(localStorage.getItem(PROGRESS_KEY) || '{"questionsDone":0,"guidesRead":0,"examsTaken":0,"lastStudy":null}');
    // 累加已做题目数 (假设这次考试做了total道题)
    if (typeof total !== 'undefined') {
      progress.questionsDone = (progress.questionsDone || 0) + total;
    }
    // 累加考试次数
    progress.examsTaken = (progress.examsTaken || 0) + 1;
    // 更新最近学习时间
    progress.lastStudy = new Date().toISOString();
    localStorage.setItem(PROGRESS_KEY, JSON.stringify(progress));
  } catch(e) {  }
  
  // 保存成绩记录到历史
  saveExamResult({
    type: '模拟考试',
    score: score,
    total: total,
    correct: correct,
    percentage: score
  });
  
  // 将错题保存到错题本
  if(wrongList && wrongList.length > 0) {
    wrongList.forEach(function(item) {
      saveWrongQuestion({
        question: item.question.question,
        options: item.question.options,
        correctAnswer: item.correctAnswer,
        userAnswer: item.userAnswer,
        type: item.question.type,
        subject: item.question.subject || '未分类'
      });
    });
  }
}

function retakeExam() {
  document.getElementById('examResult').classList.add('hidden');
  document.getElementById('examSection').classList.remove('hidden');
  startExam();
}

// ========== 错题本功能 ==========
function getWrongQuestions() {
  try { return JSON.parse(localStorage.getItem('wrongQuestions') || '[]'); }
  catch(e) { return []; }
}

function saveWrongQuestion(q) {
  var wrong = getWrongQuestions();
  // 避免重复（按题目文本去重）
  var exists = wrong.some(function(w) { return w.question === q.question; });
  if (!exists) {
    wrong.push({
      question: q.question,
      options: q.options,
      correctAnswer: q.correctAnswer,
      userAnswer: q.userAnswer,
      type: q.type,
      subject: q.subject || '未分类',
      timestamp: Date.now()
    });
    localStorage.setItem('wrongQuestions', JSON.stringify(wrong));
  }
}

function clearWrongQuestions() {
  localStorage.removeItem('wrongQuestions');
  renderWrongBook();
}

function escapeHtml(text) {
  if (!text) return '';
  var div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

function renderWrongBook() {
  var wrong = getWrongQuestions();
  var container = document.getElementById('wrong-book-content');
  if (!container) return;
  
  if (wrong.length === 0) {
    container.innerHTML = '<div class="wrong-empty"><div class="wrong-empty-icon">🎉</div><div class="wrong-empty-text">错题本为空</div><div class="wrong-empty-desc">太棒了！继续加油！</div><a href="javascript:switchMode(\'daily\')" class="wrong-empty-btn">去做题</a></div>';
    return;
  }
  
  var html = '<div class="wrong-header"><span class="wrong-count">共 ' + wrong.length + ' 道错题</span><button class="wrong-clear-btn" onclick="if(confirm(\'确定清空错题本？\'))clearWrongQuestions()">清空错题本</button></div>';
  
  wrong.forEach(function(q, i) {
    var qType = q.type === 'multi' ? '多选题' : q.type === 'judge' ? '判断题' : '单选题';
    var userAnswerText = q.userAnswer !== undefined ? (Array.isArray(q.userAnswer) ? q.userAnswer.map(function(a){return q.options[a]||a;}).join(', ') : q.options[q.userAnswer] || q.userAnswer) : '未作答';
    var correctAnswerText = Array.isArray(q.correctAnswer) ? q.correctAnswer.map(function(a){return q.options[a]||a;}).join(', ') : q.options[q.correctAnswer] || q.correctAnswer;
    
    html += '<div class="wrong-card">';
    html += '<div class="wrong-card-header"><span class="wrong-card-num">第' + (i+1) + '题</span><span class="wrong-card-subject">' + escapeHtml(qType) + '</span></div>';
    html += '<div class="wrong-card-question">' + escapeHtml(q.question) + '</div>';
    html += '<div class="wrong-card-answer wrong-user">✗ 你的答案: ' + escapeHtml(userAnswerText) + '</div>';
    html += '<div class="wrong-card-answer wrong-correct">✓ 正确答案: ' + escapeHtml(correctAnswerText) + '</div>';
    html += '</div>';
  });
  
  html += '<div class="wrong-footer"><button class="wrong-redo-btn" onclick="redoWrongQuestions()">全部重做</button></div>';
  container.innerHTML = html;
}

function redoWrongQuestions() {
  var wrong = getWrongQuestions();
  if (wrong.length === 0) return;
  // 将错题转为每日一练模式
  dailyQuestions = wrong;
  dailyUserAnswers = {};
  dailyAnswered = {};
  dailyQIndex = 0;
  // 清空错题本
  clearWrongQuestions();
  // 切换到每日一练
  switchMode('daily');
  renderDailyQuestions();
}

// ========== 成绩记录功能 ==========
function getExamHistory() {
  try { return JSON.parse(localStorage.getItem('examHistory') || '[]'); }
  catch(e) { return []; }
}

function saveExamResult(result) {
  var history = getExamHistory();
  history.push({
    type: result.type || '练习',
    score: result.score || 0,
    total: result.total || 0,
    correct: result.correct || 0,
    percentage: result.percentage || 0,
    timestamp: Date.now()
  });
  localStorage.setItem('examHistory', JSON.stringify(history));
}

function clearExamHistory() {
  localStorage.removeItem('examHistory');
  renderStats();
}

function renderStats() {
  var history = getExamHistory();
  var container = document.getElementById('stats-content');
  if (!container) return;
  
  if (history.length === 0) {
    container.innerHTML = '<div class="wrong-empty"><div class="wrong-empty-icon">📊</div><div class="wrong-empty-text">暂无考试记录</div><div class="wrong-empty-desc">完成一次考试后，这里会展示你的成绩分析</div><a href="javascript:switchMode(\'daily\')" class="wrong-empty-btn">去做题</a></div>';
    return;
  }
  
  var totalExams = history.length;
  var avgPercent = Math.round(history.reduce(function(s,h){return s+h.percentage},0) / totalExams);
  var bestScore = Math.max.apply(null, history.map(function(h){return h.percentage}));
  
  var html = '<div class="stats-cards">';
  html += '<div class="stat-card-item"><div class="stat-card-num">' + totalExams + '</div><div class="stat-card-label">考试次数</div></div>';
  html += '<div class="stat-card-item"><div class="stat-card-num">' + avgPercent + '%</div><div class="stat-card-label">平均正确率</div></div>';
  html += '<div class="stat-card-item"><div class="stat-card-num">' + bestScore + '%</div><div class="stat-card-label">最高正确率</div></div>';
  html += '</div>';
  
  // 简单柱状图
  var recentHistory = history.slice(-10);
  html += '<div class="trend-section"><h4 class="trend-title">成绩趋势</h4><div class="trend-chart">';
  recentHistory.forEach(function(h, i) {
    var height = Math.max(4, h.percentage);
    var color = h.percentage >= 60 ? '#4C8BF5' : '#EF5350';
    html += '<div class="trend-bar-group"><div class="trend-bar" style="height:' + height + '%;background:' + color + '"></div><div class="trend-bar-label">#' + (i+1) + '</div></div>';
  });
  html += '</div></div>';
  
  // 历史记录列表
  html += '<div class="history-list"><h4 class="trend-title">历史记录</h4>';
  history.slice().reverse().slice(0, 20).forEach(function(h, i) {
    var date = new Date(h.timestamp);
    var dateStr = date.getFullYear() + '-' + String(date.getMonth()+1).padStart(2,'0') + '-' + String(date.getDate()).padStart(2,'0');
    var scoreText = h.type === '模拟考试' ? h.score + '分' : h.correct + '/' + h.total;
    html += '<div class="history-item"><span class="history-rank">#' + (history.length - i) + '</span><span class="history-type">' + escapeHtml(h.type) + '</span><span class="history-score">' + scoreText + '</span><span class="history-date">' + dateStr + '</span></div>';
  });
  html += '</div>';
  
  html += '<div class="wrong-footer"><button class="wrong-clear-btn" onclick="if(confirm(\'确定清空历史记录？\'))clearExamHistory()">清空记录</button></div>';
  
  container.innerHTML = html;
}

// ========== 其他功能 ==========
function updateCountdown() {
  const examDate = new Date('2026-11-21T00:00:00');
  const now = new Date();
  const diff = examDate - now;
  if (diff <= 0) {
    (document.getElementById('days')||{}).textContent= '0';
    (document.getElementById('hours')||{}).textContent= '0';
    (document.getElementById('minutes')||{}).textContent= '0';
    (document.getElementById('seconds')||{}).textContent= '0';
    return;
  }
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
  const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
  const seconds = Math.floor((diff % (1000 * 60)) / 1000);
  (document.getElementById('days')||{}).textContent= days;
  (document.getElementById('hours')||{}).textContent= hours;
  (document.getElementById('minutes')||{}).textContent= minutes;
  (document.getElementById('seconds')||{}).textContent= seconds;
}
setInterval(updateCountdown, 1000);

function calculateScore() {
  const s1 = parseFloat(document.getElementById('score1').value) || 0;
  const s2 = parseFloat(document.getElementById('score2').value) || 0;
  const s3 = parseFloat(document.getElementById('score3').value) || 0;
  const s4 = parseFloat(document.getElementById('score4').value) || 0;
  const total = s1 + s2 + s3 + s4;
  const resultBox = document.getElementById('scoreResult');
  const statusEl = document.getElementById('resultStatus');
  const detailEl = document.getElementById('resultDetail');
  resultBox.classList.add('show');
  if (total >= 210 && s4 >= 30) {
    statusEl.textContent = '🎉 预估通过！';
    statusEl.className = 'status';
    detailEl.textContent = `总分 ${total}分（需≥210分） | 地方导基 ${s4}分（需≥30分）`;
  } else if (total >= 180) {
    statusEl.textContent = '⚠️ 有希望，再努力一点';
    statusEl.className = 'status';
    detailEl.textContent = `总分 ${total}分（需≥210分） | 还差 ${Math.max(0, 210 - total)}分`;
  } else {
    statusEl.textContent = '❌ 差距较大，加强复习';
    statusEl.className = 'status fail';
    detailEl.textContent = `总分 ${total}分（需≥210分） | 还差 ${Math.max(0, 210 - total)}分`;
  }
}

window.addEventListener('scroll', () => {
  document.getElementById('backToTop').classList.toggle('show', window.scrollY > 400);
});
function scrollToTop() { window.scrollTo({ top: 0, behavior: 'smooth' }); }
document.getElementById('navLinks').classList.remove('open');
</script>


<script>
// ========== Mode Switching ==========
function switchMode(mode) {
  // Hide all sections
  document.getElementById('dailySection').style.display = 'none';
  document.getElementById('examSection').style.display = 'none';
  document.getElementById('examResult').style.display = 'none';
  document.getElementById('wrongSection') && (document.getElementById('wrongSection').style.display = 'none');
  document.getElementById('statsSection') && (document.getElementById('statsSection').style.display = 'none');

  // Remove active from all mode-tabs
  document.querySelectorAll('.mode-tab').forEach(function(t) { t.classList.remove('active'); });

  // Show selected section
  if (mode === 'daily') {
    document.getElementById('dailySection').style.display = 'block';
    document.getElementById('tabDaily').classList.add('active');
    renderDailyQuestions();
  } else if (mode === 'exam') {
    document.getElementById('examSection').style.display = 'block';
    document.getElementById('tabExam').classList.add('active');
    startExam();
  } else if (mode === 'wrong') {
    if (!document.getElementById('wrongSection')) {
      var ws = document.createElement('div');
      ws.id = 'wrongSection';
      document.querySelector('.container').appendChild(ws);
    }
    document.getElementById('wrongSection').style.display = 'block';
    document.getElementById('tabWrong').classList.add('active');
    renderWrongBook();
  } else if (mode === 'stats') {
    if (!document.getElementById('statsSection')) {
      var ss = document.createElement('div');
      ss.id = 'statsSection';
      document.querySelector('.container').appendChild(ss);
    }
    document.getElementById('statsSection').style.display = 'block';
    document.getElementById('tabStats').classList.add('active');
    renderStats();
  }
}

// ========== Daily Question Bank ==========
var dailyBank = [
  {q:"根据《旅游法》，旅行社应当向导游支付不低于当地最低工资标准的报酬，这一规定体现了什么原则？",o:["A.公平原则","B.保障原则","C.平等原则","D.诚信原则"],a:1,exp:"《旅游法》第38条规定，旅行社应当与其聘用的导游依法订立劳动合同，支付劳动报酬，不得要求导游垫付费用，体现了保障原则。"},
  {q:"导游在进行导游活动时，其行为规范由哪部法律来规范？",o:["A.合同法","B.旅游法","C.消费者权益保护法","D.民法通则"],a:1,exp:"导游行为主要由《旅游法》规范，同时受《导游管理办法》等行政法规约束。"},
  {q:"旅行社组织团队旅游，应当与旅游者订立什么？",o:["A.口头协议","B.旅游合同","C.谅解备忘录","D.行程确认单"],a:1,exp:"《旅游法》第57条规定，旅行社组织和安排旅游活动，应当与旅游者订立书面旅游合同。"},
  {q:"导游证的有效期为几年？",o:["A.1年","B.2年","C.3年","D.5年"],a:2,exp:"《导游管理办法》规定，导游证的有效期为3年。"},
  {q:"以下哪项不属于导游的权利？",o:["A.获取劳动报酬","B.人身权","C.自由变更行程","D.参加培训"],a:2,exp:"导游无权自由变更行程，行程变更需经旅行社同意并告知旅游者。"},
  {q:"导游人员在导游活动中损害旅游者合法权益的，应当承担什么责任？",o:["A.只由旅行社承担","B.导游和旅行社连带责任","C.只由导游承担","D.不承担任何责任"],a:1,exp:"导游在导游活动中损害旅游者合法权益，旅行社和导游依法承担连带责任。"},
  {q:"根据规定，取得导游证需要通过什么考试？",o:["A.全国导游资格考试","B.省级导游考试","C.旅行社内部考核","D.旅游局面试"],a:0,exp:"《旅游法》规定，参加全国导游资格考试合格方可取得导游证。"},
  {q:"旅行社变更旅游行程安排需经过谁同意？",o:["A.只需导游同意","B.只需旅行社同意","C.需征得旅游者同意","D.不需任何人同意"],a:2,exp:"《旅游法》第69条规定，旅行社经征得旅游者同意，可以变更行程安排。"},
  {q:"旅游者在旅游活动中受到损害，有权要求赔偿的时效为多久？",o:["A.6个月","B.1年","C.2年","D.3年"],a:1,exp:"旅游纠纷的诉讼时效一般为2年（民法典），但旅游者向旅游质监部门投诉的时效为90天。此处按旅游投诉时效为60日。但考试常考2年民事时效。"},
  {q:"导游应当遵守的职业道德不包括以下哪项？",o:["A.爱岗敬业","B.诚实守信","C.以权谋私","D.遵纪守法"],a:2,exp:"以权谋私违反职业道德，导游应做到爱岗敬业、诚实守信、遵纪守法。"},
  {q:"以下哪个是导游服务的基本特点？",o:["A.独立性","B.关联性","C.季节性","D.分散性"],a:0,exp:"导游服务的基本特点包括独立性、脑体高度结合、复杂性和跨文化性。"},
  {q:"导游服务的核心是？",o:["A.购物安排","B.讲解服务","C.食宿安排","D.交通安排"],a:1,exp:"导游服务的核心是讲解服务，通过讲解使旅游者获得知识和审美享受。"},
  {q:"地陪导游的服务对象是？",o:["A.出境旅游者","B.入境旅游者","C.本地旅游者","D.所有旅游者"],a:1,exp:"地陪导游主要服务入境旅游者，负责在当地进行导游讲解和安排相关服务。"},
  {q:"导游在团队出发前的准备工作不包括？",o:["A.熟悉接待计划","B.准备导游词","C.与旅游者签订合同","D.检查所需物品"],a:2,exp:"签订合同是旅行社的工作，不是导游出发前的准备内容。"},
  {q:"以下哪项是导游在旅游途中应做的？",o:["A.随意更改行程","B.关注旅游者安全","C.强制购物","D.索要小费"],a:1,exp:"导游在旅游途中应关注旅游者安全，不得随意更改行程、强制购物或索要小费。"},
  {q:"全陪导游的职责是？",o:["A.负责景点讲解","B.负责全程陪同","C.负责餐饮安排","D.负责购物安排"],a:1,exp:"全陪导游负责全程陪同旅游团，协调联络，处理突发事件，保障旅游者权益。"},
  {q:"导游语言的基本要求不包括？",o:["A.准确","B.生动","C.夸张","D.规范"],a:2,exp:"导游语言要求准确、生动、规范，夸张不是基本要求。"},
  {q:"导游在接待外国旅游者时，应当遵守的基本原则是？",o:["A.内外有别","B.不卑不亢","C.唯利是图","D.有求必应"],a:1,exp:"导游接待外国旅游者应做到不卑不亢、热情友好，维护国家利益和民族尊严。"},
  {q:"《旅游法》正式施行的时间是？",o:["A.2013年4月25日","B.2013年10月1日","C.2014年1月1日","D.2014年10月1日"],a:1,exp:"《中华人民共和国旅游法》于2013年4月25日通过，2013年10月1日起施行。"},
  {q:"以下哪项属于导游的义务？",o:["A.收取小费","B.维护旅游者合法权益","C.擅自改变行程","D.私自承揽业务"],a:1,exp:"维护旅游者合法权益是导游的法定义务，其他三项均属于导游不得做的行为。"},
  {q:"导游证的注册管理机关是？",o:["A.人力资源部门","B.旅游行政管理部门","C.工商行政部门","D.公安部门"],a:1,exp:"导游证由旅游行政管理部门（现为文化和旅游主管部门）注册管理。"},
  {q:"导游在讲解中应遵循的原则是？",o:["A.以购物为主","B.以讲解为主","C.以娱乐为主","D.以餐饮为主"],a:1,exp:"导游讲解应遵循以讲解为主的原则，提供高质量的导游服务。"},
  {q:"旅游安全事故发生后，导游首先应做什么？",o:["A.继续行程","B.报告旅行社","C.保护现场并组织抢救","D.追究责任"],a:2,exp:"导游在旅游安全事故发生后，应立即保护现场、组织抢救，并报告旅行社和相关部门。"},
  {q:"导游带团中突发地震，应首先？",o:["A.打电话报警","B.组织旅游者有序撤离","C.原地不动等待救援","D.先自己逃生"],a:1,exp:"导游在突发地震时应组织旅游者有序撤离到安全地带，确保旅游者安全。"},
  {q:"以下哪种行为违反了《导游管理办法》？",o:["A.佩戴导游证","B.私自转借导游证","C.参加培训","D.按规定执业"],a:1,exp:"私自转借导游证违反《导游管理办法》，导游证不得转借、涂改。"},
  {q:"中国四大佛教名山中，属于安徽的是？",o:["A.五台山","B.峨眉山","C.九华山","D.普陀山"],a:2,exp:"九华山位于安徽省池州市，是中国佛教四大名山之一，地藏菩萨道场。"},
  {q:"「桂林山水甲天下」形容的是哪个景区？",o:["A.漓江","B.西湖","C.太湖","D.滇池"],a:0,exp:"「桂林山水甲天下」形容的是广西桂林漓江风景区，以喀斯特地貌闻名。"},
  {q:"北京的故宫旧称是？",o:["A.颐和园","B.紫禁城","C.圆明园","D.天坛"],a:1,exp:"北京故宫旧称紫禁城，是中国明清两代的皇家宫殿，世界最大古建筑群。"},
  {q:"以下哪个不属于中国五岳？",o:["A.泰山","B.华山","C.黄山","D.嵩山"],a:2,exp:"中国五岳为东岳泰山、西岳华山、南岳衡山、北岳恒山、中岳嵩山，黄山不属于五岳。"},
  {q:"导游讲解的常用方法不包括？",o:["A.简单概述法","B.分段讲解法","C.画龙点睛法","D.默读法"],a:3,exp:"默读法不属于导游讲解方法，常用方法有简单概述法、分段讲解法、画龙点睛法、触景生情法等。"},
  {q:"旅游者在旅游途中患病，导游应如何处理？",o:["A.自行给药","B.劝其就医并报告旅行社","C.不予理会","D.让旅游者自行处理"],a:1,exp:"旅游者患病时，导游应劝其就医，及时报告旅行社，并协助联系医院。"},
  {q:"中国最长的河流是？",o:["A.黄河","B.珠江","C.长江","D.淮河"],a:2,exp:"长江全长6300公里，是中国最长的河流，也是世界第三大河流。"},
  {q:"导游在行程结束后，需要做的工作不包括？",o:["A.填写结算单","B.归还物品","C.与旅游者签订下次旅行合同","D.总结汇报"],a:2,exp:"与旅游者签订下次旅行合同不是导游行程结束后的工作内容。"},
  {q:"以下哪项是旅游合同应包含的内容？",o:["A.旅游行程安排","B.导游私人电话","C.旅行社利润","D.其他游客信息"],a:0,exp:"旅游合同应包含旅游行程安排、交通住宿标准、旅游费用、违约责任等。"},
  {q:"导游服务中，「图文声像」属于哪种导游方式？",o:["A.实地导游","B.物化导游","C.语音导游","D.虚拟导游"],a:1,exp:"图文声像导游属于物化导游，是以实物方式向旅游者提供导游服务。"},
  {q:"以下哪个省份有「彩云之南」的美称？",o:["A.贵州","B.四川","C.云南","D.广西"],a:2,exp:"云南省因位于云岭以南，素有「彩云之南」的美称。"},
  {q:"导游接待计划确认后，应提前多久与司机联系？",o:["A.当天早上","B.提前一天","C.提前两天","D.不需要联系"],a:1,exp:"导游应在出团前一天与司机联系确认接团时间和地点。"},
  {q:"旅游投诉处理机构处理投诉的时限是？",o:["A.15个工作日","B.30个工作日","C.45个工作日","D.60个工作日"],a:2,exp:"旅游投诉处理机构应当在受理投诉之日起45个工作日内做出处理决定。"},
  {q:"导游领队引导文明旅游的规范要求，以下哪项正确？",o:["A.只在出发前提醒","B.全程提醒引导","C.不需要提醒","D.只在景点提醒"],a:1,exp:"导游领队应全程提醒引导旅游者文明旅游，不得以任何方式纵容不文明行为。"},
  {q:"以下哪种情况可以解除旅游合同？",o:["A.旅游者不想去了","B.旅行社未按约定提供服务","C.天气稍差","D.旅游者心情不好"],a:1,exp:"旅行社未按约定提供服务属于违约，旅游者有权解除合同并要求赔偿。"}
];

var dailyQuestions = [];
var dailyQIndex = 0;
var dailyAnswered = {};
var dailyCorrect = 0;

function renderDailyQuestions() {
  var container = document.getElementById('dailyQuestions');
  if (!container) return;

  // If already rendered, don't re-render
  if (container.querySelector('.question-card')) return;

  // Random shuffle questions
  var shuffled = dailyBank.slice().sort(function() { return Math.random() - 0.5; });
  dailyQuestions = shuffled.slice(0, dailyBank.length);
  dailyQIndex = 0;
  dailyAnswered = {};
  dailyCorrect = 0;

  // Show one question at a time (card/stack style)
  showDailyQuestion(0);
}

function showDailyQuestion(idx) {
  var container = document.getElementById('dailyQuestions');
  if (!container || idx >= dailyQuestions.length) return;
  dailyQIndex = idx;
  var q = dailyQuestions[idx];
  var total = dailyQuestions.length;

  var html = '<div style="text-align:center;margin-bottom:16px;">';
  html += '<div style="font-size:0.78rem;color:#999;margin-bottom:4px;">本次共 ' + total + ' 题</div>';
  html += '<div style="display:flex;justify-content:center;gap:6px;align-items:center;">';
  // Progress dots
  var maxDots = Math.min(total, 20);
  for(var d=0;d<maxDots;d++){
    var dotColor = d < idx ? '#10B981' : d === idx ? '#4C8BF5' : '#E5E7EB';
    html += '<span style="width:8px;height:8px;border-radius:50%;background:'+dotColor+';display:inline-block;"></span>';
  }
  if(total > 20) html += '<span style="font-size:0.7rem;color:#999;">...</span>';
  html += '</div></div>';

  html += '<div class="question-card" style="background:#fff;border:1px solid #F0F0F0;border-radius:20px;padding:20px;margin-bottom:14px;box-shadow:0 2px 8px rgba(0,0,0,0.04);">';
  html += '<div style="font-size:0.85rem;color:#4C8BF5;font-weight:700;margin-bottom:12px;">第 ' + (idx+1) + ' 题 / ' + total + '</div>';
  html += '<div class="question-text" style="font-size:1rem;color:#333;line-height:1.8;margin-bottom:16px;font-weight:500;">' + q.q + '</div>';
  html += '<ul class="question-options" style="list-style:none;padding:0;margin:0;">';
  q.o.forEach(function(opt, j) {
    html += '<li onclick="answerDaily(' + idx + ',' + j + ')" style="display:flex;align-items:center;gap:12px;padding:14px 16px;margin-bottom:10px;background:#F8F9FA;border:1.5px solid #F0F0F0;border-radius:14px;cursor:pointer;transition:all .2s;touch-action:manipulation;" class="daily-opt" id="dopt-' + idx + '-' + j + '">';
    html += '<span style="width:28px;height:28px;border:2px solid #4C8BF5;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;flex-shrink:0;background:#F0F5FF;color:#4C8BF5;font-weight:700;">' + String.fromCharCode(65+j) + '</span>';
    html += '<span style="font-size:0.9rem;color:#444;flex:1;line-height:1.5;">' + opt.replace(/^[A-D]\.\s*/, '') + '</span>';
    html += '</li>';
  });
  html += '</ul>';
  html += '<div id="dexp-' + idx + '" style="display:none;margin-top:12px;padding:12px 16px;background:#F0F5FF;border-radius:12px;font-size:0.85rem;color:#666;line-height:1.7;"></div>';
  html += '<div id="dnext-' + idx + '" style="display:none;margin-top:14px;text-align:center;"></div>';
  html += '</div>';

  html += '<div style="text-align:center;padding:10px 0;" id="dailyResult"></div>';
  container.innerHTML = html;
}

function answerDaily(qIdx, optIdx) {
  if (dailyAnswered[qIdx] !== undefined) return;
  dailyAnswered[qIdx] = optIdx;

  var q = dailyQuestions[qIdx];
  var isCorrect = optIdx === q.a;

  if (isCorrect) {
    dailyCorrect++;
    var el = document.getElementById('dopt-' + qIdx + '-' + optIdx);
    if (el) { el.style.background = '#ECFDF5'; el.style.borderColor = '#10B981'; }
    // Game system reward
    if (typeof GameSystem !== 'undefined' && GameSystem.addXP) {
      GameSystem.addXP(5);
      GameSystem.addCoins(2);
    }
  } else {
    var wrongEl = document.getElementById('dopt-' + qIdx + '-' + optIdx);
    if (wrongEl) { wrongEl.style.background = '#FEF2F2'; wrongEl.style.borderColor = '#EF4444'; }
    var correctEl = document.getElementById('dopt-' + qIdx + '-' + q.a);
    if (correctEl) { correctEl.style.background = '#ECFDF5'; correctEl.style.borderColor = '#10B981'; }
    // Save wrong question
    saveWrongQuestion(q);
  }

  // Show explanation
  var expEl = document.getElementById('dexp-' + qIdx);
  if (expEl) {
    expEl.innerHTML = (isCorrect ? '✅ 正确！' : '❌ 错误！') + '<br>' + q.exp;
    expEl.style.display = 'block';
  }

  // Disable all options for this question
  q.o.forEach(function(_, j) {
    var opt = document.getElementById('dopt-' + qIdx + '-' + j);
    if (opt) { opt.style.pointerEvents = 'none'; opt.style.opacity = '0.7'; }
  });

  // Show next button or result
  var nextEl = document.getElementById('dnext-' + qIdx);
  if (nextEl) {
    if (qIdx < dailyQuestions.length - 1) {
      nextEl.innerHTML = '<button onclick="showDailyQuestion(' + (qIdx+1) + ')" style="background:#4C8BF5;color:#fff;border:none;padding:14px 40px;border-radius:25px;font-size:0.95rem;font-weight:600;cursor:pointer;touch-action:manipulation;">下一题 →</button>';
      nextEl.style.display = 'block';
    } else {
      // Last question - show result
      var resultEl = document.getElementById('dailyResult');
      if (resultEl) {
        var pct = Math.round(dailyCorrect / dailyQuestions.length * 100);
        var emoji = pct >= 80 ? '🎉' : pct >= 60 ? '👍' : '💪';
        resultEl.innerHTML = '<div style="background:#fff;border:1px solid #F0F0F0;border-radius:20px;padding:24px;text-align:center;margin-top:10px;box-shadow:0 2px 8px rgba(0,0,0,0.04);"><div style="font-size:2.5rem;margin-bottom:10px;">' + emoji + '</div><div style="font-size:1.2rem;font-weight:700;color:#1A1A1A;margin-bottom:6px;">练习完成！</div><div style="font-size:1rem;color:#666;">答对 ' + dailyCorrect + ' / ' + dailyQuestions.length + ' 题（' + pct + '%）</div><button onclick="resetDailyPractice()" style="margin-top:16px;background:#4C8BF5;color:#fff;border:none;padding:12px 32px;border-radius:25px;font-size:0.9rem;font-weight:600;cursor:pointer;">再练一次</button></div>';
      }
    }
  }

  // (Result now shown via dnext button above)

  // Track in game system
  if (typeof GameSystem !== 'undefined' && GameSystem.addXP) {
    GameSystem.state.totalQuestions = (GameSystem.state.totalQuestions || 0) + dailyQuestions.length;
    GameSystem.chkSt && GameSystem.chkSt();
  }
}

function resetDailyPractice() {
  dailyQIndex = 0;
  dailyAnswered = {};
  dailyCorrect = 0;
  var container = document.getElementById('dailyQuestions');
  if(container) container.innerHTML = '';
  renderDailyQuestions();
}

function resetDaily() {
  dailyQuestions = [];
  dailyQIndex = 0;
  dailyAnswered = {};
  dailyCorrect = 0;
  var container = document.getElementById('dailyQuestions');
  if (container) container.innerHTML = '';
  renderDailyQuestions();
  window.scrollTo({top: 0, behavior: 'smooth'});
}

// 页面加载初始化
if (typeof switchMode === 'function') {
  switchMode('daily');
}

// Safety net: if loading state persists after 3s, force re-render
setTimeout(function(){
  var c = document.getElementById('dailyQuestions');
  if(c && c.querySelector('.loading-state')){
    console.log('Forcing daily questions re-render...');
    c.innerHTML = '';
    renderDailyQuestions();
  }
}, 3000);
</script>

<script>
// GameSystem stub - 替代gamification.js，不创建任何UI元素
if(typeof GameSystem==='undefined'){
  window.GameSystem={
    state:{sp:{},ach:{},stats:{total:0,streak:0}},
    addAIChat:function(){},
    chkAch:function(){},
    chkSt:function(){},
    resetDaily:function(){}
  };
}
</script>
