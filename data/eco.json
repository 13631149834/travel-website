{
  "meta": {
    "title": "环保旅行指南",
    "description": "探索绿色旅行方式，减少碳足迹，保护自然环境"
  },
  "eco_tips": {
    "reduce_plastic": {
      "title": "减少塑料使用",
      "icon": "🧴",
      "tips": [
        {
          "title": "自带水杯",
          "description": "随身携带可重复使用的水杯，拒绝一次性塑料瓶",
          "impact": "每少买1瓶矿泉水，减少约25g塑料垃圾"
        },
        {
          "title": "环保餐具",
          "description": "携带可重复使用的餐具套装，拒绝一次性筷子和塑料餐具",
          "impact": "每餐减少约50g塑料垃圾"
        },
        {
          "title": "环保购物袋",
          "description": "随身携带布袋或折叠购物袋，减少塑料袋使用",
          "impact": "每次购物减少1-3个塑料袋"
        },
        {
          "title": "拒绝塑料吸管",
          "description": "使用竹制或不锈钢吸管，拒绝塑料吸管",
          "impact": "每根塑料吸管需要500年才能降解"
        },
        {
          "title": "减少包装食品",
          "description": "购买散装食品，选择无包装或可回收包装商品",
          "impact": "减少不必要的塑料包装"
        }
      ]
    },
    "save_resources": {
      "title": "节约资源",
      "icon": "💧",
      "tips": [
        {
          "title": "缩短淋浴时间",
          "description": "将淋浴时间控制在5分钟以内，节约用水",
          "impact": "每次缩短2分钟，可节约约20升水"
        },
        {
          "title": "随手关灯关空调",
          "description": "离开房间时关闭电源和空调，减少能源消耗",
          "impact": "每关闭1小时，节约约0.5度电"
        },
        {
          "title": "重复使用毛巾",
          "description": "在酒店期间重复使用毛巾，减少洗涤次数",
          "impact": "每少洗一次，节约约50升水"
        },
        {
          "title": "合理使用空调",
          "description": "将空调温度设置在26℃以上，减少能源消耗",
          "impact": "每提高1℃，节能约6%"
        },
        {
          "title": "减少纸张使用",
          "description": "使用电子凭证和票据，减少纸张打印",
          "impact": "减少树木砍伐，保护森林"
        }
      ]
    },
    "green_travel": {
      "title": "绿色出行",
      "icon": "🚲",
      "tips": [
        {
          "title": "选择公共交通",
          "description": "优先选择地铁、公交等公共交通工具",
          "impact": "相比自驾，公共交通碳排放减少约75%"
        },
        {
          "title": "骑行探索",
          "description": "在短距离出行时选择骑行或步行",
          "impact": "零碳排放，健康环保"
        },
        {
          "title": "拼车出行",
          "description": "与同行者拼车，减少车辆数量",
          "impact": "每拼车1次，减少约50%碳排放"
        },
        {
          "title": "选择火车",
          "description": "中短途旅行优先选择火车而非飞机",
          "impact": "火车碳排放约为飞机的1/4"
        },
        {
          "title": "直飞航班",
          "description": "必须飞行时选择直飞，减少起降碳排放",
          "impact": "直飞比中转减少约30%碳排放"
        }
      ]
    },
    "eco_accommodation": {
      "title": "环保住宿",
      "icon": "🏨",
      "tips": [
        {
          "title": "选择绿色酒店",
          "description": "入住获得环保认证的酒店",
          "impact": "支持可持续发展旅游业"
        },
        {
          "title": "减少床品更换",
          "description": "无需每天更换床单被罩，减少洗涤用水用电",
          "impact": "每少换一次，节约约50升水"
        },
        {
          "title": "节约用水用电",
          "description": "在住宿期间养成节约用水用电的习惯",
          "impact": "减少资源浪费，降低碳足迹"
        },
        {
          "title": "使用小型洗漱用品",
          "description": "自备洗漱用品，减少酒店一次性用品",
          "impact": "减少塑料垃圾产生"
        },
        {
          "title": "关注酒店环保措施",
          "description": "选择有太阳能热水、雨水回收等环保设施的住宿",
          "impact": "支持环保技术创新"
        }
      ]
    },
    "waste_sorting": {
      "title": "垃圾分类",
      "icon": "♻️",
      "tips": [
        {
          "title": "了解分类标准",
          "description": "提前了解目的地的垃圾分类标准",
          "impact": "正确分类提高回收效率"
        },
        {
          "title": "随身携带垃圾袋",
          "description": "在野外或旅途中随身携带垃圾袋",
          "impact": "不乱扔垃圾，保护环境"
        },
        {
          "title": "厨余垃圾处理",
          "description": "食物残渣单独收集，不混入其他垃圾",
          "impact": "厨余垃圾可堆肥处理"
        },
        {
          "title": "可回收物分离",
          "description": "将塑料、纸张、玻璃、金属等可回收物分离",
          "impact": "提高资源回收利用率"
        },
        {
          "title": "有害垃圾特殊处理",
          "description": "电池、药品等有害垃圾需特殊处理",
          "impact": "避免环境污染"
        }
      ]
    }
  },
