    {
      "src": "images/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "images/og-image.png",
      "sizes": "1200x630",
      "type": "image/png",
      "form_factor": "wide",
      "label": "游导旅游应用界面"
    },
    {
      "src": "images/icons/screenshot-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "手机端界面"
    }
  ],
  "shortcuts": [
    {
      "name": "找导游",
      "short_name": "找导游",
      "description": "搜索并预约专业导游",
      "url": "/guides.html",
      "icons": [{"src": "images/icon-192.png", "sizes": "192x192"}]
    },
    {
      "name": "精品路线",
      "short_name": "路线",
      "description": "浏览精选旅游路线",
      "url": "/routes.html",
      "icons": [{"src": "images/icon-192.png", "sizes": "192x192"}]
    },
    {
      "name": "签证服务",
      "short_name": "签证",
      "description": "快速办理各国签证",
      "url": "/visa.html",
      "icons": [{"src": "images/icon-192.png", "sizes": "192x192"}]
    },
    {
      "name": "天气查询",
      "short_name": "天气",
      "description": "查询目的地天气",
      "url": "/weather.html",
      "icons": [{"src": "images/icon-192.png", "sizes": "192x192"}]
    },
    {
      "name": "PWA功能",
      "short_name": "PWA",
      "description": "了解PWA功能",
      "url": "/pwa-features.html",
      "icons": [{"src": "images/icon-192.png", "sizes": "192x192"}]
    }
  ],
  "related_applications": [],
  "protocol_handlers": [
    {
      "protocol": "youdau",
      "url": "/%7Cpath%7C"
    }
  ],
  "share_target": {
    "action": "/share-target.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "/file-handler.html",
      "accept": [".json", ".txt"]
    }
  ]
}
